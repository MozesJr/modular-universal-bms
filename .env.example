# =============================================
# Modular Universal BMS — Environment Config
# Copy this file to .env and fill in values
# =============================================

# ─── Node ─────────────────────────────────
NODE_ENV=development

# ─── MongoDB ──────────────────────────────
MONGO_ROOT_USER=bms_admin
MONGO_ROOT_PASSWORD=supersecretpassword
MONGO_DB_NAME=bms_db

# ─── MQTT ─────────────────────────────────
# Topic pattern: bms/{pack_id}/cell/{cell_id}
MQTT_TOPIC_PREFIX=bms

# ─── Frontend Build Args ──────────────────
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
